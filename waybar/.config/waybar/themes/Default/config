{
    "layer": "top",
    "position": "top",
    "margin-top": 5,
    "margin-left": 10,
    "margin-right": 10,
    "spacing": 15,
    "modules-left": ["hyprland/workspaces", "hyprland/window", "cpu"],
    "modules-center": ["clock", "custom/spotify"],
    "modules-right": ["pulseaudio", "network", "battery", "custom/exit", "custom/reboot", "custom/power"],
    "hyprland/workspaces": {
        "format": "{icon}",
        "on-click": "activate",
        "all-outputs": true,
        "persistent-workspaces": {
            "*": 5
        },
        "format-icons": {
            "default": "ΎΕΝ",
            "active": "ΎΕΣ",
            "urgent": "ΎΒς"
        }
    },
    "hyprland/window": {
        "format": "{title}",
        "max-length": 20
    },
    "clock": {
        "format": "ΎΑΩ  {:%d.%m | %H:%M}",
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>"
    },
    "custom/spotify": {
        "format": "ΎΗ╝  ≤░Τχ  {icon}  ≤░Τφ",
        "format-icons": {
            "Playing": "≤░Πν",
            "Paused": "≤░ΡΛ",
            "default": "≤░ΡΛ"
        },
        "return-type": "json",
        "exec": "playerctl -p spotify metadata --format '{\"text\": \"{{status}}\", \"alt\": \"{{status}}\"}' 2>/dev/null || echo '{\"text\": \"Stopped\", \"alt\": \"Paused\"}'",
        "interval": 2,
        "on-click": "playerctl -p spotify play-pause",
        "on-scroll-up": "playerctl -p spotify next",
        "on-scroll-down": "playerctl -p spotify previous"
    },
    "network": {
        "format-wifi": "ΎΘτ  {essid}",
        "format-ethernet": "≤░ΙΑ  {ifname}",
        "format-disconnected": "≤░Ψς  Offline"
    },
    "battery": {
        "format": "{icon} {capacity}%",
        "format-icons": ["≤░ΓΟ", "≤░Β║", "≤░Β╗", "≤░Β╝", "≤░Β╜", "≤░Β╛", "≤░Β┐", "≤░ΓΑ", "≤░ΓΒ", "≤░ΓΓ", "≤░Β╣"]
    },
    "cpu": {
        "format": "ΎΤ╝  {usage}%"
    },
    "pulseaudio": {
        "format": "{icon} {volume}%",
	"format-muted": "Ύγσ {volume}%",
        "format-icons": { "default": ["ΎΑο ", "ΎΑπ ", "ΎΑρ "] },
        "on-click": "pavucontrol"
    },
    "custom/exit": {
        "format": "≤░ΙΗ ",
        "on-click": "hyprctl dispatch exit"
    },
    "custom/reboot": {
        "format": "≤░εΚ ",
        "on-click": "systemctl reboot"
    },
    "custom/power": {
        "format": "ΎΑΣ ",
        "on-click": "systemctl poweroff"
    }
}
