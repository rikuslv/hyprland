[global]
    width = 300
    height = 100
    offset = 20x20
    origin = top-right
    
    # Moderns stils
    corner_radius = 10        # Noapaļoti stūri
    frame_width = 2
    frame_color = "#89b4fa"   # Zila apmale (piemēram, Catppuccin tēma)
    font = JetBrains Mono 10
    padding = 15
    horizontal_padding = 15

[mouse] 
    mouse_left_click = do_action, close_current 
    mouse_right_click = close_current
